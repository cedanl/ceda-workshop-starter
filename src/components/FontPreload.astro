---
/**
 * Font Preload Component
 *
 * Preloads critical fonts to improve LCP and prevent FOUT.
 * Include this in the <head> of your layouts.
 */
const base = import.meta.env.BASE_URL;
---

<!-- Preload critical fonts for better performance -->
<link
  rel="preload"
  href={`${base}/fonts/Geist-Variable.woff2`}
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href={`${base}/fonts/GeistMono-Variable.woff2`}
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>

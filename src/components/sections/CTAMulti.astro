---
/**
 * CTAMulti Section Component
 *
 * Conversion-focused section with three parallel action cards.
 * Each card has an icon, title, description, and an external link button.
 * Built for the CEDA "Meedoen" section: GitHub, Npuls, Community.
 *
 * @example
 * ```astro
 * <CTAMulti
 *   title="Doe mee"
 *   subtitle="Vind je plek in het CEDA-ecosysteem"
 *   cards={[
 *     {
 *       icon: "github",
 *       title: "GitHub",
 *       description: "Bekijk en fork de open-source projecten.",
 *       href: "https://github.com/cedanl",
 *       label: "Bekijk code",
 *     },
 *   ]}
 * />
 * ```
 *
 * @customization
 * - Add icons to iconPaths to support more icon names
 * - Adjust grid columns via the grid class on the cards container
 * - Change card background via bg-card / hover:bg-muted/50 classes
 */

interface CTACard {
  title: string;
  description: string;
  href: string;
  label: string;
  icon?: 'github' | 'globe' | 'users' | 'zap' | 'chart' | 'shield';
}

interface Props {
  title?: string;
  subtitle?: string;
  cards: CTACard[];
}

const { title, subtitle, cards } = Astro.props;

const iconPaths: Record<string, string> = {
  github:
    'M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z',
  globe:
    'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z',
  users:
    'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  zap: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  chart: 'M18 20V10M12 20V4M6 20v-6',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
};
---

<section class="py-20 md:py-28 px-6 bg-muted/30">
  <div class="container max-w-5xl mx-auto">
    {
      (title || subtitle) && (
        <div class="flex flex-col items-center space-y-4 text-center mb-12" data-animate>
          {title && (
            <h2 class="text-3xl font-bold leading-[1.1] sm:text-3xl md:text-5xl">{title}</h2>
          )}
          {subtitle && (
            <p class="max-w-[85%] leading-normal text-muted-foreground sm:text-lg sm:leading-7">
              {subtitle}
            </p>
          )}
        </div>
      )
    }

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        cards.map((card, index) => (
          <div
            class="group relative flex flex-col rounded-xl border bg-card p-8 shadow-sm hover:shadow-md transition-shadow"
            data-animate
            data-delay={String(Math.min(index + 1, 3))}
          >
            {card.icon && (
              <div class="inline-flex p-2 border border-foreground rounded-xl mb-5 w-fit">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-5 w-5"
                  aria-hidden="true"
                >
                  <path d={iconPaths[card.icon] ?? iconPaths.zap} />
                </svg>
              </div>
            )}

            <h3 class="text-xl font-semibold mb-3">{card.title}</h3>

            <p class="text-sm text-muted-foreground leading-relaxed flex-1">{card.description}</p>

            <a
              href={card.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 mt-6 rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors text-sm font-medium h-10 px-6 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
            >
              {card.label}
              <svg
                class="h-3.5 w-3.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

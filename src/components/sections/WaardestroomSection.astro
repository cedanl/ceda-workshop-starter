---
import WaardestroomTool from '@/components/ceda/WaardestroomTool';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Waardestroom per doelgroep',
  subtitle = 'Kies een rol en een stap in de reis — zie welke tools en use cases beschikbaar zijn.',
} = Astro.props;
---

<section>
  <div class="mx-auto max-w-[1200px] px-4 py-12 md:px-8" data-animate>
    <h2 class="font-serif text-2xl font-light text-foreground md:text-3xl">{title}</h2>
    <p class="mt-1.5 max-w-[720px] text-sm text-muted-foreground">{subtitle}</p>
  </div>
  <WaardestroomTool client:visible />
</section>

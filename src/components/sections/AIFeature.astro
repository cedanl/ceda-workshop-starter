---
/**
 * AI Feature Section
 *
 * Highlights the AI-friendly development features of AstroDeck.
 * Built on the AGENTS.md standard supported by 60,000+ repositories.
 * Uses lobe-icons (https://github.com/lobehub/lobe-icons) for tool logos.
 */

const tools = [
  {
    name: 'OpenAI Codex',
    url: 'https://openai.com/codex/',
    subtitle: 'Native support',
    icon: 'openai',
  },
  {
    name: 'GitHub Copilot',
    url: 'https://github.com/features/copilot',
    subtitle: 'Coding Agent',
    icon: 'githubcopilot',
  },
  {
    name: 'Cursor',
    url: 'https://cursor.com',
    subtitle: 'Native support',
    icon: 'cursor',
  },
  {
    name: 'Google Jules',
    url: 'https://jules.google',
    subtitle: 'Native support',
    icon: 'gemini',
  },
  {
    name: 'Gemini CLI',
    url: 'https://github.com/google-gemini/gemini-cli',
    subtitle: 'Terminal agent',
    icon: 'gemini',
  },
  {
    name: 'Windsurf',
    url: 'https://windsurf.com',
    subtitle: 'Agentic IDE',
    icon: 'windsurf',
  },
  {
    name: 'VS Code',
    url: 'https://code.visualstudio.com',
    subtitle: 'Copilot Agent',
    icon: 'microsoft',
  },
  {
    name: 'Claude Code',
    url: 'https://claude.ai/code',
    subtitle: '+ Custom Agent',
    icon: 'claude',
  },
];

const iconBaseUrl = '/icons/ai-tools';
---

<section class="py-24 px-6 bg-muted/30">
  <div class="container max-w-5xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left Column: Text -->
      <div class="space-y-6">
        <div
          class="inline-block px-3 py-1 bg-primary/10 text-primary text-sm font-medium rounded-full"
        >
          AI-Friendly Development
        </div>
        <h2 class="text-3xl md:text-5xl font-bold leading-tight">Built for AI coding assistants</h2>

        <!-- AGENTS.md Standard -->
        <p class="text-muted-foreground leading-relaxed">
          AI without a system produces slop — hardcoded colors, broken dark mode, random spacing.
          AstroDeck gives your coding agent a real operating environment instead: conventions via
          the <a
            href="https://agents.md"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary underline hover:no-underline font-medium">AGENTS.md standard</a
          > (used by 60,000+ open-source projects, stewarded by the Linux Foundation), so every tool in
          the grid knows your project's patterns before it writes a single line.
        </p>

        <!-- Claude Code Agent + Guardrails -->
        <p class="text-muted-foreground leading-relaxed">
          And the rules are enforced, not just written down: a convention guard hook blocks
          off-system edits before they reach your code, and one command checks every design
          convention at once. <a
            href="https://github.com/holger1411/astrodeck#-ai-friendly-development"
            class="text-primary underline hover:no-underline font-medium">Claude Code</a
          > gets the deepest integration — a dedicated agent with seven domain skills that warns about
          security, accessibility, and SEO issues proactively.
        </p>
      </div>

      <!-- Right Column: Tools Grid -->
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-px bg-border overflow-hidden rounded-xl border shadow-lg">
          {
            tools.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative overflow-hidden bg-card px-6 py-6 hover:bg-muted/50 transition-colors"
              >
                <div class="mb-3 h-8 w-8">
                  <img
                    src={`${iconBaseUrl}/${tool.icon}.svg`}
                    alt={`${tool.name} logo`}
                    width="32"
                    height="32"
                    class="h-8 w-8 dark:invert"
                    loading="lazy"
                  />
                </div>
                <h3 class="text-xl font-semibold mb-1 group-hover:text-primary transition-colors">
                  {tool.name}
                </h3>
                <p class="text-sm text-muted-foreground">{tool.subtitle}</p>
              </a>
            ))
          }
        </div>

        <!-- More Tools -->
        <p class="text-sm text-muted-foreground">
          Plus: Zed, Aider, Factory, Amp, RooCode, <a
            href="https://agents.md"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary underline hover:no-underline">and many more</a
          >.
        </p>
      </div>
    </div>
  </div>
</section>

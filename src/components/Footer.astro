---
/**
 * Footer Component
 *
 * Unified footer with boxed and fullWidth variants.
 * Contains navigation links, resources, and creator info.
 *
 * @example
 * ```astro
 * <Footer />
 * <Footer variant="fullWidth" />
 * ```
 */
import Logo from './Logo.astro';

interface Props {
  /** Layout variant - boxed (default) or fullWidth */
  variant?: 'boxed' | 'fullWidth';
}

const { variant = 'boxed' } = Astro.props;

const footerLinks = {
  ceda: [
    { href: '/', label: 'Home' },
    { href: 'https://github.com/cedanl', label: 'GitHub' },
    { href: 'https://npuls.nl/', label: 'Npuls' },
  ],
  community: [
    {
      href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
      label: 'Community',
    },
    { href: 'https://github.com/cedanl', label: 'Bijdragen' },
  ],
};

const containerClass =
  variant === 'fullWidth' ? 'w-full px-4' : 'container max-w-5xl mx-auto px-4 sm:px-6';
---

<footer class="border-t bg-background">
  <div class:list={[containerClass, 'py-12']}>
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <Logo />
        <p class="mt-4 text-sm text-muted-foreground">
          Center for Educational Data Analytics — open tools en kennis voor data-analyse in het
          onderwijs.
        </p>
      </div>

      <!-- CEDA -->
      <div>
        <h3 class="font-semibold mb-4">CEDA</h3>
        <ul class="space-y-0">
          {
            footerLinks.ceda.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-block py-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="font-semibold mb-4">Meedoen</h3>
        <ul class="space-y-0">
          {
            footerLinks.community.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-block py-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Npuls -->
      <div>
        <h3 class="font-semibold mb-4">Onderdeel van</h3>
        <a
          href="https://npuls.nl/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          Npuls
        </a>
        <p class="text-sm text-muted-foreground mt-2">
          Nationaal programma voor digitale en educatieve innovatie in het hoger onderwijs.
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 border-t pt-8 text-center text-sm text-muted-foreground">
      <p>
        &copy; {new Date().getFullYear()} CEDA — Center for Educational Data Analytics. Onderdeel van
        Npuls.
      </p>
    </div>
  </div>
</footer>

---
/**
 * Footer Component
 *
 * Unified footer with boxed and fullWidth variants.
 * Contains navigation links, resources, and creator info.
 *
 * @example
 * ```astro
 * <Footer />
 * <Footer variant="fullWidth" />
 * ```
 */
import Logo from './Logo.astro';

interface Props {
  /** Layout variant - boxed (default) or fullWidth */
  variant?: 'boxed' | 'fullWidth';
}

const { variant = 'boxed' } = Astro.props;

const footerLinks = {
  links: [
    { href: 'https://github.com/cedanl', label: 'GitHub', external: true },
    { href: 'https://npuls.nl/', label: 'Npuls', external: true },
    {
      href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
      label: 'Community',
      external: true,
    },
  ],
  sections: [
    { href: '#menukaart', label: 'Aanbod' },
    { href: '#over', label: 'Over CEDA' },
    { href: '#meedoen', label: 'Meedoen' },
  ],
};

const containerClass =
  variant === 'fullWidth' ? 'w-full px-4' : 'container max-w-5xl mx-auto px-4 sm:px-6';
---

<footer class="border-t bg-background">
  <div class:list={[containerClass, 'py-12']}>
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <Logo />
        <p class="mt-4 text-sm text-muted-foreground">
          Open data-analyse voor het Nederlandse hoger onderwijs. Open source, samen gebouwd.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-4">Links</h3>
        <ul class="space-y-0">
          {
            footerLinks.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  class="inline-block py-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Secties -->
      <div>
        <h3 class="font-semibold mb-4">Secties</h3>
        <ul class="space-y-0">
          {
            footerLinks.sections.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-block py-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Initiatief van -->
      <div>
        <h3 class="font-semibold mb-4">Initiatief van</h3>
        <p class="text-sm text-muted-foreground">
          CEDA is onderdeel van
          <a
            href="https://npuls.nl/"
            class="font-medium text-foreground hover:text-primary transition-colors inline-flex items-center gap-1 py-1"
            target="_blank"
            rel="noopener noreferrer"
          >
            Npuls
            <svg
              class="h-3 w-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
          </a>
          — het samenwerkingsprogramma voor digitalisering in het hoger onderwijs.
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 border-t pt-8 text-center text-sm text-muted-foreground">
      <p>
        &copy; {new Date().getFullYear()} CEDA — Center for Educational Data Analytics. Onderdeel van
        <a
          href="https://npuls.nl/"
          class="hover:text-foreground transition-colors underline underline-offset-2"
          target="_blank"
          rel="noopener noreferrer"
        >
          Npuls
        </a>.
      </p>
    </div>
  </div>
</footer>

---
/**
 * Logo Component
 *
 * AstroDeck brand logo with card deck icon and wordmark.
 * Used consistently across Header, Footer, and Auth layouts.
 *
 * @example
 * ```astro
 * <Logo />
 * <Logo showText={false} />
 * <Logo size="lg" />
 * ```
 */
interface Props {
  /** Show the "AstroDeck" text next to the icon */
  showText?: boolean;
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
}

const { showText = true, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'h-5 w-5',
  md: 'h-6 w-6',
  lg: 'h-8 w-8',
};

const textSizeClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
};
---

<a href="/" class:list={['flex items-center space-x-2', className]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="currentColor"
    class={sizeClasses[size]}
    aria-hidden="true"
  >
    <rect x="2" y="17" width="7" height="13" rx="1.5" opacity="0.6"></rect>
    <rect x="12" y="9" width="7" height="21" rx="1.5" opacity="0.8"></rect>
    <rect x="22" y="3" width="7" height="27" rx="1.5"></rect>
  </svg>
  {showText && <span class:list={['font-bold', textSizeClasses[size]]}>CEDA</span>}
</a>

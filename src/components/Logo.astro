---
/**
 * Logo Component
 *
 * AstroDeck brand logo with card deck icon and wordmark.
 * Used consistently across Header, Footer, and Auth layouts.
 *
 * @example
 * ```astro
 * <Logo />
 * <Logo showText={false} />
 * <Logo size="lg" />
 * ```
 */
interface Props {
  /** Show the "AstroDeck" text next to the icon */
  showText?: boolean;
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
}

const { showText = true, size = 'md', class: className = '' } = Astro.props;

const base = import.meta.env.BASE_URL;

const sizeClasses = {
  sm: 'h-5 w-5',
  md: 'h-6 w-6',
  lg: 'h-8 w-8',
};

const textSizeClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
};
---

<a href={`${base}/`} class:list={['flex items-center space-x-2', className]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linejoin="round"
    class={sizeClasses[size]}
    aria-hidden="true"
  >
    <!-- Comic panel frame with a little bar chart inside (data + strip) -->
    <rect x="4" y="4" width="24" height="24" rx="2"></rect>
    <path d="M11 22 V16 M16 22 V11 M21 22 V18" stroke-linecap="round"></path>
  </svg>
  {
    showText && (
      <span class:list={['font-black uppercase tracking-tight', textSizeClasses[size]]}>CEDA</span>
    )
  }
</a>

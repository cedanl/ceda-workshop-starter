---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Stats from '@/components/sections/Stats.astro';
import ValueStreamSection from '@/components/sections/ValueStreamSection.astro';
import DataSources from '@/components/sections/DataSources.astro';
import { DOELGROEPEN, STREAMS, USE_CASES, ALLE_BRONNEN } from '@/data/ceda';

const totalSteps = Object.values(STREAMS).reduce((sum, steps) => sum + steps.length, 0);

const stats = [
  {
    value: String(DOELGROEPEN.length),
    label: 'Doelgroepen',
    description: 'Elk met een eigen waardestroom',
  },
  {
    value: String(totalSteps),
    label: 'Stappen in kaart',
    description: 'Van werving tot arbeidsmarkt',
  },
  {
    value: String(USE_CASES.length),
    label: 'Use cases & tools',
    description: 'Beschikbaar, in ontwikkeling of als idee',
  },
  {
    value: String(ALLE_BRONNEN.length),
    label: 'Databronnen',
    description: 'Ontsloten en gepland',
  },
];
---

<BaseLayout
  title="CEDA — Center for Educational Data Analytics"
  description="CEDA volgt de waardestroom van vijf doelgroepen door het onderwijs — van leven-lang-lerende tot bestuurder — en ontsluit de analyses, tools en databronnen die elke stap ondersteunen."
>
  <!-- HERO -->
  <section class="bg-ceda-hero px-4 py-20 md:px-8 md:py-28">
    <div class="mx-auto grid max-w-[1200px] items-center gap-12 lg:grid-cols-2">
      <div data-animate="fade">
        <p class="mb-5 text-xs font-medium uppercase tracking-[0.14em] text-ceda-primary">
          Center for Educational Data Analytics
        </p>
        <h1
          class="mb-6 text-balance font-serif text-4xl font-light leading-tight text-foreground md:text-5xl lg:text-6xl"
        >
          Datagedreven onderwijs begint hier
        </h1>
        <p class="mb-10 max-w-[480px] text-lg leading-relaxed text-muted-foreground">
          CEDA volgt de reis van vijf doelgroepen door het onderwijs — van leven-lang-lerende tot
          bestuurder. Kies een rol en zie welke analyses, tools en use cases elke stap ondersteunen,
          en waar nog kansen liggen.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="#stream"
            class="inline-flex items-center gap-2 rounded-full bg-ceda-primary px-7 py-3 text-sm font-medium text-ceda-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ceda-link focus-visible:ring-offset-2"
          >
            Bekijk de waardestroom
            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true"
              class="flex-none"
            >
              <path
                d="M1 7h12M7 1l6 6-6 6"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="https://github.com/cedanl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background/60 px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ceda-link focus-visible:ring-offset-2"
          >
            GitHub
          </a>
          <a
            href="https://npuls.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background/60 px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ceda-link focus-visible:ring-offset-2"
          >
            Npuls
          </a>
          <a
            href="https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background/60 px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ceda-link focus-visible:ring-offset-2"
          >
            Community
          </a>
        </div>
      </div>
      <div class="hidden lg:grid lg:grid-cols-2 lg:gap-3" aria-hidden="true" data-animate="fade">
        {
          stats.map((stat) => (
            <div class="rounded-xl bg-background/80 p-5">
              <div class="font-serif text-4xl font-light leading-none text-ceda-primary">
                {stat.value}
              </div>
              <div class="mt-1.5 text-sm text-muted-foreground">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- KEY NUMBERS -->
  <Stats stats={stats} />

  <!-- THE VALUE STREAM — centerpiece -->
  <ValueStreamSection />

  <!-- ALL DATA SOURCES -->
  <DataSources />
</BaseLayout>

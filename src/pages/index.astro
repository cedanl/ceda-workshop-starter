---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Features from '@/components/sections/Features.astro';
import Stats from '@/components/sections/Stats.astro';

const aanbod = [
  {
    title: 'Open Source Tools',
    description:
      'CEDA ontwikkelt open source tools voor onderwijsdata-analyse. Vrij te gebruiken en bij te dragen via GitHub.',
    icon: 'zap',
  },
  {
    title: 'Datasets & Inzichten',
    description:
      'Toegang tot geanonimiseerde onderwijsdatasets en analyses die instellingen helpen beter te begrijpen wat werkt.',
    icon: 'chart',
  },
  {
    title: 'Community & Samenwerking',
    description:
      'Een groeiende community van onderzoekers, docenten en beleidsmakers die kennis en ervaringen delen.',
    icon: 'users',
  },
  {
    title: 'Onderzoeksprojecten',
    description:
      'CEDA loopt mee in Npuls-projecten gericht op datagedreven verbetering van het Nederlandse onderwijs.',
    icon: 'globe',
  },
  {
    title: 'Kennisdeling',
    description:
      'Workshops, webinars en documentatie om iedereen in het onderwijs te helpen met data aan de slag te gaan.',
    icon: 'shield',
  },
  {
    title: 'Open Standaarden',
    description:
      'We werken met open standaarden zodat onze tools breed inzetbaar zijn, ongeacht je instelling of systeem.',
    icon: 'lock',
  },
];
---

<BaseLayout
  title="CEDA — Center for Educational Data Analytics"
  description="CEDA helpt het Nederlandse onderwijs vooruit met open data-tools, onderzoek en een actieve community van onderzoekers, docenten en bestuurders."
>
  <Hero
    title="Data voor beter onderwijs."
    subtitle="CEDA — het <mark>Center for Educational Data Analytics</mark> — brengt open tools, onderzoek en een actieve <mark>community</mark> samen voor iedereen in het Nederlandse onderwijs."
    primaryCta={{ href: '/meedoen', label: 'Doe mee' }}
    secondaryCta={{ href: '/aanbod', label: 'Bekijk het aanbod' }}
  />

  <div class="section-inverted py-8">
    <Stats
      stats={[
        { value: 'Open', label: 'Source', description: 'Vrij te gebruiken & bij te dragen' },
        { value: 'NL', label: 'Onderwijs', description: 'Gericht op het Nederlandse stelsel' },
        { value: 'Npuls', label: 'Partner', description: 'Onderdeel van het Npuls-programma' },
        { value: '100%', label: 'Community', description: 'Gedreven door samenwerking' },
      ]}
    />
  </div>

  <Features
    title="Wat CEDA te bieden heeft"
    subtitle="Van open source tools tot kennisdeling — CEDA ondersteunt iedereen in het onderwijs die met data aan de slag wil."
    features={aanbod}
  />

  <div class="section-inverted">
    <section class="py-20 md:py-32 px-6">
      <div class="container max-w-3xl mx-auto text-center" data-animate="scale">
        <h2 class="text-3xl font-bold leading-tight md:text-5xl">Klaar om mee te doen?</h2>
        <p class="mt-6 text-lg text-muted-foreground max-w-xl mx-auto leading-relaxed">
          Sluit je aan bij de CEDA-community, verken de open source projecten op GitHub of lees meer
          over het Npuls-programma.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-10 justify-center">
          <a
            href="/meedoen"
            class="group relative inline-flex items-center justify-center whitespace-nowrap rounded-md text-base font-semibold ring-offset-background transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 hover:scale-105 h-12 px-12 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 overflow-hidden"
          >
            <span
              class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"
              aria-hidden="true"></span>
            <span
              class="relative z-10 inline-block transition-transform duration-300 group-hover:translate-x-0.5"
              >Doe mee</span
            >
          </a>
          <a
            href="https://github.com/cedanl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-12 px-8"
          >
            GitHub
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

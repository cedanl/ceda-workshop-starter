---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Features from '@/components/sections/Features.astro';
import Stats from '@/components/sections/Stats.astro';
import CTA from '@/components/sections/CTA.astro';

const features = [
  {
    title: 'Open Source Tools',
    description:
      'Alle CEDA-tools zijn open source en vrij te gebruiken. Bekijk, hergebruik en draag bij via GitHub.',
    icon: 'globe',
  },
  {
    title: 'Kant-en-klare Analyses',
    description:
      'Reproduceerbare notebooks en scripts voor veelvoorkomende onderwijsvraagstukken — direct inzetbaar in jouw instelling.',
    icon: 'chart',
  },
  {
    title: 'Actieve Community',
    description:
      'Verbind met data-analisten en onderzoekers uit het hele onderwijsveld. Deel ervaringen, stel vragen en leer van elkaar.',
    icon: 'users',
  },
  {
    title: 'Kennisdeling',
    description:
      'Workshops, documentatie en handleidingen in het Nederlands. Van beginners tot gevorderden — iedereen kan meedoen.',
    icon: 'lock',
  },
  {
    title: 'Onderdeel van Npuls',
    description:
      'CEDA is een initiatief van Npuls, het nationale programma voor digitale en educatieve innovatie in het hoger onderwijs.',
    icon: 'shield',
  },
  {
    title: 'Snel van start',
    description:
      'Installeer een tool, volg de documentatie en ga aan de slag. Van installatie naar inzicht in korte tijd.',
    icon: 'zap',
  },
];
---

<BaseLayout
  title="Center for Educational Data Analytics"
  description="CEDA helpt onderwijsinstellingen om data begrijpelijk en bruikbaar te maken — met open tools, gedeelde kennis en een actieve community."
>
  <Hero
    title="Data-analyse voor het onderwijs."
    subtitle="CEDA helpt onderwijsinstellingen om data <mark>begrijpelijk en bruikbaar</mark> te maken — met <mark>open source tools</mark>, gedeelde kennis en een <mark>actieve community</mark>."
    primaryCta={{
      href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
      label: 'Word lid van de community',
    }}
    secondaryCta={{ href: 'https://github.com/cedanl', label: 'GitHub' }}
  />

  <Features
    title="Wat CEDA te bieden heeft"
    subtitle="Van open tools tot een actieve kenniscommunity — alles om data-analyse in het onderwijs toegankelijker te maken."
    features={features}
  />

  <div class="section-inverted py-8">
    <Stats
      stats={[
        {
          value: '50+',
          label: 'Open Source Tools',
          description: 'Vrij te gebruiken en aan bij te dragen',
        },
        {
          value: '100+',
          label: 'Community Leden',
          description: 'Analisten en onderzoekers uit het onderwijs',
        },
        {
          value: '30+',
          label: 'Instellingen',
          description: 'HO- en MBO-instellingen actief betrokken',
        },
        {
          value: 'Npuls',
          label: 'Programma',
          description: 'Nationaal programma voor digitale innovatie',
        },
      ]}
    />
  </div>

  <CTA
    title="Doe mee met de CEDA Community"
    description="Sluit je aan bij honderden data-professionals uit het onderwijs. Stel vragen, deel projecten en bouw samen aan de toekomst van onderwijsdata."
    cta={{
      href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
      label: 'Naar de community',
    }}
  />
</BaseLayout>

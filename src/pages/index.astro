---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Features from '@/components/sections/Features.astro';
import ContentBlock from '@/components/sections/ContentBlock.astro';
import CTAMulti from '@/components/sections/CTAMulti.astro';

const menukaartFeatures = [
  {
    icon: 'zap',
    title: 'Open-source tools',
    description:
      'Herbruikbare data-analyse-scripts en tools voor IR, onderzoek en beleidswerk — direct van GitHub.',
    href: 'https://github.com/cedanl',
  },
  {
    icon: 'shield',
    title: 'Gedeelde standaarden',
    description:
      'Afspraken en formaten die samenwerking tussen instellingen mogelijk maken zonder het wiel opnieuw uit te vinden.',
  },
  {
    icon: 'users',
    title: 'Community & kennisdeling',
    description:
      'Een actieve community van data-analisten en IR-medewerkers in het hoger onderwijs.',
    href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
  },
  {
    icon: 'chart',
    title: 'Projecten',
    description:
      'Concrete projecten die door instellingen samen worden gedragen en openbaar beschikbaar zijn.',
    href: 'https://github.com/cedanl',
  },
];

const meedoenCards = [
  {
    icon: 'github' as const,
    title: 'GitHub',
    description:
      'Bekijk de open-source code, fork projecten en lever bij. Alle tools en standaarden staan publiek op de CEDA-organisatiepagina.',
    href: 'https://github.com/cedanl',
    label: 'Bekijk op GitHub',
  },
  {
    icon: 'globe' as const,
    title: 'Npuls',
    description:
      'Lees meer over het Npuls-programma en de bredere context van digitalisering in het Nederlandse hoger onderwijs.',
    href: 'https://npuls.nl/',
    label: 'Naar Npuls',
  },
  {
    icon: 'users' as const,
    title: 'Community',
    description:
      'Sluit je aan bij de community van data-professionals in het hoger onderwijs. Stel vragen, deel ervaringen en werk samen.',
    href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
    label: 'Sluit je aan',
  },
];
---

<BaseLayout
  title="Data-analyse voor het hoger onderwijs"
  description="CEDA bundelt open data-analyse-tools, standaarden en een community voor het Nederlandse hoger onderwijs. Doe mee via GitHub, Npuls of de community."
>
  <!-- Sectie 1: Hero -->
  <Hero
    title="CEDA — data-analyse voor het hoger onderwijs"
    subtitle="Open, herbruikbaar en samen gebouwd binnen Npuls."
    primaryCta={{
      href: 'https://community-data-ai.npuls.nl/groups/view/44d20066-53a8-48c2-b4e9-be348e05d273/project-center-for-educational-data-analytics-ceda',
      label: 'Doe mee via de community',
    }}
    secondaryCta={{
      href: 'https://github.com/cedanl',
      label: 'Bekijk op GitHub',
    }}
  />

  <!-- Sectie 2: Menukaart -->
  <div id="menukaart">
    <Features
      title="Wat CEDA biedt"
      subtitle="Tools, standaarden en community voor data-professionals in het hoger onderwijs"
      features={menukaartFeatures}
      columns={4}
    />
  </div>

  <!-- Sectie 3: Over CEDA -->
  <div id="over">
    <ContentBlock
      tagline="Over CEDA"
      title="Samen sterker in data-analyse"
      description="CEDA — het Center for Educational Data Analytics — bundelt expertise en tools voor data-professionals in het Nederlandse hoger onderwijs. Als onderdeel van Npuls werken hogescholen en universiteiten samen aan open, herbruikbare oplossingen. Geen concurrentie, maar gedeelde kracht."
      features={[
        'Open source — alle code staat publiek op GitHub',
        'Onderdeel van het Npuls-samenwerkingsprogramma',
        'Actieve community van data-analisten en IR-medewerkers',
      ]}
      imageSide="right"
    />
  </div>

  <!-- Sectie 4: Meedoen -->
  <div id="meedoen">
    <CTAMulti
      title="Doe mee"
      subtitle="Vind je plek in het CEDA-ecosysteem — of je nu code wilt bijdragen, de context wilt begrijpen of gewoon wilt aansluiten."
      cards={meedoenCards}
    />
  </div>
</BaseLayout>
